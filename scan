#!/bin/bash

# ===============================
# PS5 REAL ACTIVITY MONITOR
# ===============================

if [ "$EUID" -ne 0 ]; then
    echo "Run with sudo ./ps5_monitor.sh"
    exit 1
fi

echo "🎮 PS5 REAL ACTIVITY MONITOR"
echo ""

read -p "Enter PS5 IP: " PS5_IP

echo ""
echo "[*] Detecting active interfaces..."

# Find interfaces with traffic
IFS=$'\n'
INTERFACES=($(ip -o link show | awk -F': ' '{print $2}'))

BEST_IF=""
BEST_COUNT=0

for IFACE in "${INTERFACES[@]}"; do
    COUNT=$(timeout 2 tcpdump -i "$IFACE" host "$PS5_IP" -nn 2>/dev/null | wc -l)
    if [ "$COUNT" -gt "$BEST_COUNT" ]; then
        BEST_COUNT=$COUNT
        BEST_IF=$IFACE
    fi
done

if [ -z "$BEST_IF" ] || [ "$BEST_COUNT" -eq 0 ]; then
    echo "❌ No traffic detected from PS5"
    echo "👉 Make sure:"
    echo "   - PS5 is ON"
    echo "   - Same network"
    echo "   - Correct IP"
    exit 1
fi

echo "✅ Using interface: $BEST_IF"
sleep 1

RATE_FILE="/tmp/ps5_rate.txt"
> $RATE_FILE

echo "[+] Monitoring started..."
sleep 1

# Capture traffic (lightweight)
tcpdump -i "$BEST_IF" host "$PS5_IP" -nn -l 2>/dev/null | while read line; do
    echo "$(date +%s)" >> $RATE_FILE
done &

# Display loop
while true; do
    clear
    NOW=$(date +%s)

    echo "🎮 PS5 ACTIVITY MONITOR"
    echo "Time: $(date)"
    echo "PS5: $PS5_IP"
    echo "Interface: $BEST_IF"
    echo "======================================"

    # Packet rate (last 2 seconds)
    RATE=$(awk -v now=$NOW '$1 > now-2' $RATE_FILE | wc -l)

    echo "📊 Packets (last 2s): $RATE"

    # Activity interpretation
    if [ "$RATE" -lt 5 ]; then
        echo "😴 Idle / no party activity"
    elif [ "$RATE" -lt 30 ]; then
        echo "🎮 Normal gameplay traffic"
    elif [ "$RATE" -lt 80 ]; then
        echo "💬 Party activity detected"
    else
        echo "🎤 Voice spike (someone talking)"
    fi

    # VPN detection hint
    UNIQUE_IPS=$(timeout 2 tcpdump -i "$BEST_IF" host "$PS5_IP" -nn 2>/dev/null \
        | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' \
        | sort | uniq | wc -l)

    if [ "$UNIQUE_IPS" -le 2 ]; then
        echo ""
        echo "⚠️ Likely VPN or PSN relay (limited visibility)"
    fi

    echo "======================================"
    sleep 2
done
