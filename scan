#!/bin/bash

# ===============================
# PS5 SMART PARTY MONITOR v2
# ===============================

if [ "$EUID" -ne 0 ]; then
    echo "Run with sudo ./ps5_monitor.sh"
    exit 1
fi

echo "🎮 PS5 SMART PARTY MONITOR"
sleep 1

read -p "Enter PS5 IP: " PS5_IP
read -p "Enter interface (wifi/hotspot): " IFACE

DATA="/tmp/ps5_data.txt"
LAST="/tmp/ps5_last.txt"
RATE="/tmp/ps5_rate.txt"

> $DATA
> $LAST
> $RATE

echo "[+] Starting capture..."

# Capture traffic
tcpdump -i $IFACE host $PS5_IP -nn -l 2>/dev/null | while read line; do
    NOW=$(date +%s)

    # Count packets for rate detection
    echo "$NOW" >> $RATE

    echo "$line" | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}\.[0-9]+' | while read ep; do
        IP=$(echo $ep | sed 's/\.[0-9]*$//')
        PORT=$(echo $ep | grep -oE '[0-9]+$')

        if [ "$IP" != "$PS5_IP" ]; then
            KEY="$IP:$PORT"

            # Track last seen
            grep -v "^$KEY " $LAST > ${LAST}.tmp
            echo "$KEY $NOW" >> ${LAST}.tmp
            mv ${LAST}.tmp $LAST

            # New connection alert
            if ! grep -q "^$KEY$" "$DATA"; then
                echo "$KEY" >> "$DATA"
                echo "[NEW] $KEY"
            fi
        fi
    done
done &

# Display loop
while true; do
    clear
    NOW=$(date +%s)

    echo "🎮 PS5 SMART MONITOR"
    echo "Time: $(date)"
    echo "Target: $PS5_IP"
    echo "Interface: $IFACE"
    echo "======================================"

    sort $DATA | uniq > /tmp/ps5_unique.txt
    COUNT=$(wc -l < /tmp/ps5_unique.txt)

    # VPN detection (very useful)
    UNIQUE_IPS=$(cut -d: -f1 /tmp/ps5_unique.txt | sort | uniq | wc -l)
    if [ "$UNIQUE_IPS" -le 2 ]; then
        echo "⚠️ VPN LIKELY ACTIVE (low peer count)"
    else
        echo "🌐 Direct Connections Detected"
    fi

    echo "Endpoints: $COUNT"
    echo ""

    # Packet rate (voice/activity detection)
    RECENT=$(awk -v now=$NOW '$1 > now-2' $RATE | wc -l)
    echo "📊 Traffic Rate: $RECENT pkts/2s"

    if [ "$RECENT" -gt 50 ]; then
        echo "🎤 High activity (possible voice/chat spike)"
    fi

    echo ""
    echo "--------------------------------------"

    while read ep; do
        LAST_SEEN=$(grep "^$ep " $LAST | tail -n1 | awk '{print $2}')
        AGE=$((NOW - LAST_SEEN))

        if [ "$AGE" -lt 3 ]; then
            STATUS="🟢 ACTIVE"
        else
            STATUS="🔴 IDLE"
        fi

        IP=$(echo $ep | cut -d: -f1)

        # Classify traffic
        if echo "$IP" | grep -qE "^(10\.|172\.16\.|192\.168\.)"; then
            TYPE="🏠 LOCAL"
        else
            TYPE="🌍 INTERNET"
        fi

        # Voice ports
        if echo "$ep" | grep -qE "3478|3479|3480"; then
            ACT="🎤 VOICE"
        else
            ACT=""
        fi

        echo "$ep | $TYPE | $STATUS $ACT"
    done < /tmp/ps5_unique.txt

    echo ""
    echo "======================================"
    sleep 2
done
